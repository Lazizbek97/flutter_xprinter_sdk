<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Bluetooth — declared without maxSdkVersion.  Some XPrinter SDK
         code paths still call legacy BluetoothAdapter APIs on Android
         12+ devices and require these permissions at runtime; capping
         at API 30 caused SecurityException on certain MIUI / OEM-modified
         devices.  SCAN/CONNECT below cover the normal Android 12+ paths. -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <!-- We only scan to find printers — never to derive user location.  The
         neverForLocation flag drops the implicit fine-location requirement
         on Android 12+. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- BLE scan on pre-31 needs location permission (Android requirement, not vendor SDK). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />

    <!-- TCP/IP (WiFi or Ethernet) connections. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Optional features — printer hardware varies per merchant. -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />
    <!-- Override the vendor AAR, which incorrectly makes USB host mandatory.
         Bluetooth and TCP printing do not require USB host hardware. -->
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false"
        tools:replace="android:required" />

</manifest>
